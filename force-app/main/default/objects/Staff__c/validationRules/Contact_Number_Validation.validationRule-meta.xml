<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Contact_Number_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>OR(
    ISBLANK(Contact_Number__c),
    NOT(REGEX(Contact_Number__c, &quot;[0-9]{10}&quot;))
)</errorConditionFormula>
    <errorDisplayField>Contact_Number__c</errorDisplayField>
    <errorMessage>Contact Number must contain exactly 10 digits.</errorMessage>
</ValidationRule>
