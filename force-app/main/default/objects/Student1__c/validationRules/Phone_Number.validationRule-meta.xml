<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Phone_Number</fullName>
    <active>true</active>
    <errorConditionFormula>LEN(Phone__c) &lt;&gt; 10</errorConditionFormula>
    <errorDisplayField>Phone__c</errorDisplayField>
    <errorMessage>Phone number should contain exactly 10 digits</errorMessage>
</ValidationRule>
