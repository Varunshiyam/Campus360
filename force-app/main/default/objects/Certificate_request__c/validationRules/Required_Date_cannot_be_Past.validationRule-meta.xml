<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Required_Date_cannot_be_Past</fullName>
    <active>true</active>
    <errorConditionFormula>Required_Date__c &lt; TODAY()</errorConditionFormula>
    <errorMessage>Required Date should be today or later.</errorMessage>
</ValidationRule>
