<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Phone_number_error</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(
REGEX( Phone_Number__c , &quot;^[0-9]{10}$&quot;)
)</errorConditionFormula>
    <errorMessage>Phone Number must contain exactly 10 digits.</errorMessage>
</ValidationRule>
