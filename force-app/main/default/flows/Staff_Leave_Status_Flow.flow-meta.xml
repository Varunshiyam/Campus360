    <decisions>
        <name>Check_Leave_Date</name>
        <label>Check Leave Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Keep_Staff_Active</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not On Leave</defaultConnectorLabel>
        <rules>
            <name>Currently_On_Leave</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Leave_Start_Date__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <dateValue>2026-07-09</dateValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Leave_End_Date__c</leftValueReference>
