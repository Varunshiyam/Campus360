            </connector>
            <label>Currently On Leave</label>
        </rules>
        <rules>
            <name>Leave_Completed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Leave_End_Date__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <dateValue>2026-07-09</dateValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Staff_Active</targetReference>
            </connector>
            <label>Leave Completed</label>
        </rules>
    </decisions>
